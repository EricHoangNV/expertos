// ExpertOS database schema — tenant-ready from day 1 (PRD §"Data Model").
//
// Every knowledge/content row carries `tenantId` + `scope`. `tenantId` defaults to
// the well-known GLOBAL tenant (00000000-0000-0000-0000-000000000000); the consumer
// MVP runs entirely under it with scope ∈ {global_expert, temporary_upload, user_private}.
// B2B (Phase 3) flips on the remaining scopes with no migration.
//
// Embedding columns use pgvector and are typed `Unsupported("vector(1536)")` — Prisma
// Client cannot read/write them directly; the VectorStore driver (M1) uses raw SQL.
// 1536 = OpenAI text-embedding-3-small. Changing the model means a migration.
//
// Row-Level Security policies + the pgvector index live in the hand-written
// `*_rls_and_vector` migration (Prisma cannot express RLS or index Unsupported columns).

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ───────────────────────────── Enums ─────────────────────────────

/// Origin/visibility class for every content row. Drives RLS + retrieval filters.
enum ContentScope {
  global_expert
  shared_expert
  tenant_customer
  user_private
  temporary_upload

  @@map("content_scope")
}

enum Role {
  user
  expert
  admin

  @@map("role")
}

enum Language {
  en
  vi

  @@map("language")
}

/// Versioned-knowledge lifecycle (admin publish workflow, M8).
enum PublishStatus {
  draft
  ai_processing
  expert_review
  published
  archived

  @@map("publish_status")
}

/// Retrieval-visibility status of an individual chunk.
enum ChunkStatus {
  pending
  published
  archived

  @@map("chunk_status")
}

enum MessageRole {
  user
  assistant
  system

  @@map("message_role")
}

enum BillingInterval {
  month
  year

  @@map("billing_interval")
}

enum FeatureType {
  boolean
  metered

  @@map("feature_type")
}

/// Rolling window for a metered entitlement.
enum UsageWindow {
  day
  week
  month

  @@map("usage_window")
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  incomplete_expired
  unpaid

  @@map("subscription_status")
}

enum TransactionType {
  subscription
  one_off
  refund
  adjustment

  @@map("transaction_type")
}

enum TransactionStatus {
  pending
  succeeded
  failed
  refunded

  @@map("transaction_status")
}

enum UploadMode {
  temporary
  persistent

  @@map("upload_mode")
}

enum ReviewTriggerMode {
  user_prompted
  auto_silent

  @@map("review_trigger_mode")
}

enum ReviewVisibility {
  visible
  silent

  @@map("review_visibility")
}

enum ReviewRequestStatus {
  requested
  in_review
  answered
  escalated
  dismissed

  @@map("review_request_status")
}

enum ReviewVerdict {
  good
  bad
  great

  @@map("review_verdict")
}

enum KnowledgeDraftStatus {
  draft
  expert_review
  published
  rejected

  @@map("knowledge_draft_status")
}

enum ConsultationStatus {
  recommended
  booked
  confirmed
  completed
  canceled
  no_show

  @@map("consultation_status")
}

/// Why the recommendation engine fired (admin-configurable rules, M7).
enum RecommendationTrigger {
  topic
  depth
  low_confidence
  high_intent

  @@map("recommendation_trigger")
}

/// The user's response to an in-chat consultation recommendation.
enum RecommendationResponse {
  pending
  book
  maybe_later
  ask_another

  @@map("recommendation_response")
}

enum DataDeletionStatus {
  requested
  processing
  completed
  failed

  @@map("data_deletion_status")
}

enum FairUseFlagStatus {
  open
  reviewed
  throttled
  cleared

  @@map("fair_use_flag_status")
}

// ──────────────────────── Identity / billing ────────────────────────

/// A tenant (organization). The GLOBAL tenant is seeded at the all-zero UUID.
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  experts              Expert[]
  voiceProfiles        VoiceProfile[]
  voiceExamples        VoiceExample[]
  subscriptions        Subscription[]
  usageCounters        UsageCounter[]
  usageLogs            UsageLog[]
  transactions         Transaction[]
  documents            Document[]
  documentVersions     DocumentVersion[]
  chunks               Chunk[]
  citations            Citation[]
  topics               Topic[]
  conversations        Conversation[]
  messages             Message[]
  savedAnswers         SavedAnswer[]
  answerFeedback       AnswerFeedback[]
  knowledgeDrafts      KnowledgeDraft[]
  humanReviewRequests  HumanReviewRequest[]
  reviewResponses      ReviewResponse[]
  uploadedFiles        UploadedFile[]
  uploadChunks         UploadChunk[]
  consultations        Consultation[]
  consultationRecs     ConsultationRecommendation[]
  consultationNotes    ConsultationNote[]
  semanticCacheEntries SemanticCacheEntry[]
  adminAuditLogs       AdminAuditLog[]
  dataDeletionRequests DataDeletionRequest[]
  fairUseFlags         FairUseFlag[]

  @@map("tenants")
}

/// An end user (or expert/admin — role is on the row). Identity from Firebase Auth.
model User {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  firebaseUid String   @unique @map("firebase_uid")
  email       String
  displayName String?  @map("display_name")
  role        Role     @default(user)
  locale      Language @default(en)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant               Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expert               Expert?
  subscriptions        Subscription[]
  usageCounters        UsageCounter[]
  usageLogs            UsageLog[]
  transactions         Transaction[]
  conversations        Conversation[]
  savedAnswers         SavedAnswer[]
  answerFeedback       AnswerFeedback[]
  uploadedFiles        UploadedFile[]
  humanReviewRequests  HumanReviewRequest[]
  reviewResponses      ReviewResponse[]             @relation("Reviewer")
  consultations        Consultation[]
  consultationRecs     ConsultationRecommendation[]
  dataDeletionRequests DataDeletionRequest[]
  fairUseFlags         FairUseFlag[]
  adminAuditLogs       AdminAuditLog[]              @relation("AuditActor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// An expert whose knowledge + voice the product renders.
model Expert {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId      String?  @unique @map("user_id") @db.Uuid
  slug        String
  displayName String   @map("display_name")
  title       String?
  bio         String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceProfiles VoiceProfile[]
  documents     Document[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("experts")
}

/// A versioned, expert-signed-off voice profile. Language-aware (EN + VI).
model VoiceProfile {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  expertId    String        @map("expert_id") @db.Uuid
  language    Language      @default(en)
  name        String
  description String?
  guidelines  String? // distilled voice rules injected into the prompt builder
  status      PublishStatus @default(draft)
  approvedBy  String?       @map("approved_by") @db.Uuid
  approvedAt  DateTime?     @map("approved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expert   Expert         @relation(fields: [expertId], references: [id], onDelete: Cascade)
  examples VoiceExample[]

  @@index([tenantId, expertId, language])
  @@map("voice_profiles")
}

/// A retrieval-time voice example ("this is how the expert phrases things").
model VoiceExample {
  id             String                       @id @default(uuid()) @db.Uuid
  tenantId       String                       @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  voiceProfileId String                       @map("voice_profile_id") @db.Uuid
  prompt         String?
  content        String
  language       Language                     @default(en)
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime                     @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voiceProfile VoiceProfile @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId, voiceProfileId])
  @@map("voice_examples")
}

/// A subscription plan. Reference/config data (no tenant RLS).
model Plan {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique // free | plus | premium
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prices        PlanPrice[]
  entitlements  PlanEntitlement[]
  subscriptions Subscription[]

  @@map("plans")
}

/// A plan + billing interval → provider price ID. Premium has monthly + annual.
model PlanPrice {
  id              String          @id @default(uuid()) @db.Uuid
  planId          String          @map("plan_id") @db.Uuid
  interval        BillingInterval
  amountCents     Int             @map("amount_cents")
  currency        String          @default("usd")
  providerPriceId String?         @map("provider_price_id") // Stripe price ID
  createdAt       DateTime        @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, interval])
  @@map("plan_prices")
}

/// The entitlement catalog — one key per capability. Reference/config data.
model Feature {
  id          String      @id @default(uuid()) @db.Uuid
  key         String      @unique // ask_question | document_upload | ...
  name        String
  description String?
  type        FeatureType
  createdAt   DateTime    @default(now()) @map("created_at")

  entitlements PlanEntitlement[]

  @@map("features")
}

/// The plan × feature matrix — this table *is* the free-vs-paid definition.
/// Seeded from a code default, then admin-editable.
model PlanEntitlement {
  id        String       @id @default(uuid()) @db.Uuid
  planId    String       @map("plan_id") @db.Uuid
  featureId String       @map("feature_id") @db.Uuid
  enabled   Boolean      @default(true)
  limit     Int? // null = no hard cap (for metered features)
  // Fair-use soft threshold (M6.3): once a metered feature's count passes this in the window the
  // answer is served by a cheaper model (degrade) instead of blocking. null = no degradation.
  softLimit Int?         @map("soft_limit")
  window    UsageWindow?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@map("plan_entitlements")
}

/// A user's subscription. Payment source of truth = provider; mirrored here.
model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  interval           BillingInterval    @default(month)
  status             SubscriptionStatus @default(active)
  providerCustomerId String?            @map("provider_customer_id")
  providerSubId      String?            @unique @map("provider_subscription_id")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelAt           DateTime?          @map("cancel_at")
  canceledAt         DateTime?          @map("canceled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId, userId])
  @@index([status])
  @@map("subscriptions")
}

/// Per-user, per-feature counter for the current metered window.
model UsageCounter {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  featureKey  String      @map("feature_key")
  window      UsageWindow
  windowStart DateTime    @map("window_start")
  count       Int         @default(0)
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey, window, windowStart])
  @@index([tenantId, userId])
  @@map("usage_counters")
}

/// Append-only per-action usage + cost log (cost/usage tracking, P0.5).
model UsageLog {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  featureKey       String   @map("feature_key")
  model            String?
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  costMicros       Int?     @map("cost_micros") // cost in millionths of a USD cent, integer-safe
  conversationId   String?  @map("conversation_id") @db.Uuid
  // True when this chat answer touched a high-stakes topic (financial/legal/medical/tax — NT.4),
  // logged for monitoring per PRD §"Non-Technical Requirements". Always false for non-chat usage.
  highStakes       Boolean  @default(false) @map("high_stakes")
  occurredAt       DateTime @default(now()) @map("occurred_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId])
  @@index([occurredAt])
  @@map("usage_logs")
}

/// Local revenue ledger — mirrors every provider event for reporting/reconciliation.
model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId      String?           @map("user_id") @db.Uuid
  amountCents Int               @map("amount_cents")
  currency    String            @default("usd")
  type        TransactionType
  status      TransactionStatus @default(pending)
  provider    String            @default("stripe")
  providerRef String?           @map("provider_ref") // idempotency: provider event/invoice id
  occurredAt  DateTime          @default(now()) @map("occurred_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, providerRef])
  @@index([tenantId, userId])
  @@index([occurredAt])
  @@map("transactions")
}

// ──────────────────────── Knowledge (versioned) ────────────────────────

/// A logical knowledge document. Points at its currently published version.
model Document {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  scope              ContentScope  @default(global_expert)
  expertId           String?       @map("expert_id") @db.Uuid
  title              String
  sourceUri          String?       @map("source_uri") // GCS object of the raw source
  language           Language      @default(en)
  status             PublishStatus @default(draft)
  publishedVersionId String?       @unique @map("published_version_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expert           Expert?           @relation(fields: [expertId], references: [id], onDelete: SetNull)
  publishedVersion DocumentVersion?  @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  versions         DocumentVersion[] @relation("DocumentVersions")
  topics           DocumentTopic[]

  @@index([tenantId, scope, status])
  @@map("documents")
}

/// An immutable snapshot of a document at publish/approval time.
model DocumentVersion {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  documentId    String        @map("document_id") @db.Uuid
  versionNumber Int           @map("version_number")
  status        PublishStatus @default(draft)
  changeSummary String?       @map("change_summary")
  contentUri    String?       @map("content_uri") // GCS object of the processed content
  approvedBy    String?       @map("approved_by") @db.Uuid
  approvedAt    DateTime?     @map("approved_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document     Document   @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  publishedFor Document?  @relation("PublishedVersion")
  chunks       Chunk[]
  citations    Citation[]

  @@unique([documentId, versionNumber])
  @@index([tenantId])
  @@map("document_versions")
}

/// A retrievable chunk with its embedding. Filtered by status=published + scope + tenant + language.
model Chunk {
  id                String                       @id @default(uuid()) @db.Uuid
  tenantId          String                       @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  scope             ContentScope                 @default(global_expert)
  documentVersionId String                       @map("document_version_id") @db.Uuid
  chunkIndex        Int                          @map("chunk_index")
  content           String
  summary           String?
  language          Language                     @default(en)
  status            ChunkStatus                  @default(pending)
  tokenCount        Int?                         @map("token_count")
  embedding         Unsupported("vector(1536)")?
  // Concierge "Bad"-verdict knowledge-gap signal (M9.4): how many times a reviewer flagged an
  // answer grounded on this chunk as bad, plus when it last happened. Feeds the failed-query /
  // knowledge-quality inspector (M10.3) so weak source material surfaces for re-authoring.
  flagCount         Int                          @default(0) @map("flag_count")
  lastFlaggedAt     DateTime?                    @map("last_flagged_at")
  createdAt         DateTime                     @default(now()) @map("created_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  citations       Citation[]

  @@unique([documentVersionId, chunkIndex])
  @@index([tenantId, scope, status, language])
  @@map("chunks")
}

/// Answer provenance — records the exact chunk + document_version cited.
model Citation {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  messageId         String   @map("message_id") @db.Uuid
  chunkId           String?  @map("chunk_id") @db.Uuid
  documentVersionId String?  @map("document_version_id") @db.Uuid
  uploadChunkId     String?  @map("upload_chunk_id") @db.Uuid
  ordinal           Int
  quote             String?
  createdAt         DateTime @default(now()) @map("created_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message         Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk           Chunk?           @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  documentVersion DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  uploadChunk     UploadChunk?     @relation(fields: [uploadChunkId], references: [id], onDelete: SetNull)

  @@index([tenantId, messageId])
  @@map("citations")
}

/// Topic/tag taxonomy. Tenant-scoped so B2B tenants can curate their own.
model Topic {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  slug      String
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents DocumentTopic[]

  @@unique([tenantId, slug])
  @@map("topics")
}

/// Document ↔ Topic join.
model DocumentTopic {
  documentId String @map("document_id") @db.Uuid
  topicId    String @map("topic_id") @db.Uuid

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([documentId, topicId])
  @@map("document_topics")
}

// ──────────────────────────── Conversations ────────────────────────────

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expertId  String?  @map("expert_id") @db.Uuid
  title     String?
  language  Language @default(en)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant          Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  savedAnswers    SavedAnswer[]
  knowledgeDrafts KnowledgeDraft[]
  recommendations ConsultationRecommendation[]

  @@index([tenantId, userId])
  @@map("conversations")
}

model Message {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  conversationId   String      @map("conversation_id") @db.Uuid
  role             MessageRole
  content          String
  // document_version ids whose chunks generated this answer (provenance)
  sourceVersionIds String[]    @default([]) @map("source_version_ids") @db.Uuid
  model            String?
  confidence       Float?
  // When set, this assistant message is a concierge "refined update" (M9.3) — the reviewer-edited
  // answer delivered back into the conversation — pointing at the original answer it refines. Carries
  // the OD#5 visual-indicator signal ("AI-reviewed/edited content") to the read path. Soft link (no
  // FK relation): the original cascades with the conversation, so this never dangles.
  refinedFromMessageId String? @map("refined_from_message_id") @db.Uuid
  // True when this answer touched a high-stakes topic (financial/legal/medical/tax — NT.4); carries
  // the disclaimer signal to the history read path. Always false for user messages.
  highStakes       Boolean     @default(false) @map("high_stakes")
  createdAt        DateTime    @default(now()) @map("created_at")

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  citations      Citation[]
  savedAnswers   SavedAnswer[]
  feedback       AnswerFeedback[]
  reviewRequests HumanReviewRequest[]

  @@index([tenantId, conversationId])
  @@map("messages")
}

model SavedAnswer {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  messageId      String   @map("message_id") @db.Uuid
  note           String?
