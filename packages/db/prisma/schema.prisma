/// Admin-configurable consultation-recommendation rules (M7.1) — one row per trigger.
/// Reference/config data like `plan_entitlements` (no tenant RLS): seeded from a code default,
/// then admin-editable in the portal (M8.3) so the funnel can be tuned with no deploy. The pure
/// rules engine (`@expertos/ai` `evaluateRecommendation`) reads these rows; it never hardcodes them.
model RecommendationRule {
  id      String                @id @default(uuid()) @db.Uuid
  trigger RecommendationTrigger @unique
  enabled Boolean               @default(true)
  /// `depth`: minimum assistant turns before firing; `low_confidence`: max citations still "low".
  /// Unused by `topic`/`high_intent` (keyword rules).
  threshold Int?
  /// Lowercased match terms for `topic` (in question + answer) / `high_intent` (in question only).
  /// Unused by `depth`/`low_confidence` (threshold rules).
  keywords String[] @default([])
  /// Higher wins when several rules fire on the same turn (only one recommendation is surfaced).
  priority Int @default(0)
  /// Which `consultation_types.key` to recommend booking; null falls back to the active default.
  consultationTypeKey String?  @map("consultation_type_key")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("recommendation_rules")
}

/// TidyCal booking-webhook ledger (M7.3, resolves Open Decision #10). Every verified booking event —
/// whether delivered by webhook or recovered by the reconcile poll — is recorded here, mirroring the
/// M6.2 Stripe `transactions` idempotency discipline. Two jobs:
///   1. **Idempotency** — `@@unique([provider, eventId])` makes a redelivered event a no-op (a
///      reconcile-sourced entry uses a deterministic synthetic `eventId` so re-polling is idempotent too).
///   2. **Missed-event / no-vanish recovery** — `matched=false` rows are bookings we couldn't correlate
///      to a user/consultation (e.g. a booking made outside the funnel); they are kept (never dropped)
///      so an admin can reconcile them manually instead of the booking silently vanishing.
/// Reference/system data like `recommendation_rules` (no tenant RLS): written only in the system RLS
/// context of the `@Public()` webhook / admin reconcile, read only by admins.
model BookingWebhookEvent {
  id             String    @id @default(uuid()) @db.Uuid
  /// Booking provider (e.g. `tidycal`, `offline`) — namespaces the idempotency key.
  provider       String
  /// Provider event id (webhook) or a synthetic `reconcile:<bookingRef>` key (poll) — idempotency key.
  eventId        String    @map("event_id")
  /// The normalized event kind (`booking.created` / `booking.cancelled` / `booking.rescheduled`).
  eventType      String    @map("event_type")
  /// TidyCal booking id — the correlation key back to a `consultations` row (links may be static).
  bookingRef     String?   @map("booking_ref")
  /// Booking contact email — how an inbound booking is matched to a user when no consultation exists.
  email          String?
  scheduledAt    DateTime? @map("scheduled_at")
  /// The `consultations` row this event resolved to (soft pointer; null when unmatched).
  consultationId String?   @map("consultation_id") @db.Uuid
  /// True once the event was correlated to a user/consultation; false rows await manual reconciliation.
  matched        Boolean   @default(false)
  /// The raw verified event, kept for audit / manual recovery.
  payload        Json
  receivedAt     DateTime  @default(now()) @map("received_at")

  @@unique([provider, eventId])
  @@index([bookingRef])
  @@map("booking_webhook_events")
}

// ──────────────────────────── Cache ────────────────────────────

/// Semantic question cache (normalized question → cached answer + citations).
model SemanticCacheEntry {
  id                 String                       @id @default(uuid()) @db.Uuid
  tenantId           String                       @default(dbgenerated("'00000000-0000-0000-0000-000000000000'::uuid")) @map("tenant_id") @db.Uuid
  normalizedQuestion String                       @map("normalized_question")
  embedding          Unsupported("vector(1536)")?
  chunkIds           String[]                     @default([]) @map("chunk_ids") @db.Uuid
  answer             String
  /// Resolved citations of the cached answer (M6.4), stored verbatim so a cache hit rebuilds the
  /// `done` event + persisted citation rows faithfully (the array columns can't carry ordinal/content).
  citations         Json?
  citationIds        String[]                     @default([]) @map("citation_ids") @db.Uuid
  model              String?
  hits               Int                          @default(0)
  createdAt          DateTime                     @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  // Exact-match lookup key for the M6.4 persistent answer cache (within tenant, per model tier).
  @@index([tenantId, normalizedQuestion, model])
  @@map("semantic_cache")
}

