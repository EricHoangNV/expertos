# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://expertos:expertos@localhost:5432/expertos?schema=public

# ── Firebase Auth (API — Admin SDK service account; from Secret Manager in prod) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# ── Firebase Auth (web client — NEXT_PUBLIC_*, safe to expose to the browser) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Base URL of the API the web app calls (chat streaming, experts picker).
# Defaults to http://localhost:3001 if unset. Build-time → pass as --build-arg in deploy.
NEXT_PUBLIC_API_URL=

# E2E ONLY — point the web/admin Firebase client at the local Auth emulator (host:port).
# Leave UNSET in production: when set, the client routes auth to the emulator. The API
# (firebase-admin) reads the same emulator via the standard FIREBASE_AUTH_EMULATOR_HOST.
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ── AI providers ──────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Observability ─────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────
NODE_ENV=development
API_PORT=3001
