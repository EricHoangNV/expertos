{
  "name": "expertos",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -- turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm lint:css",
    "lint:css": "stylelint \"packages/**/src/**/*.css\" \"apps/**/app/**/*.css\" \"apps/**/src/**/*.css\"",
    "deadcode": "knip",
    "test:integration": "bash infra/local-test-db.sh",
    "deploy:api": "bash infra/deploy.sh api",
    "deploy:web": "bash infra/deploy.sh web",
    "deploy:admin": "bash infra/deploy.sh admin",
    "deploy": "pnpm deploy:api && pnpm deploy:web && pnpm deploy:admin"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "knip": "5.27.0",
    "stylelint": "16.7.0",
    "stylelint-config-standard": "36.0.1",
    "ts-jest": "29.2.2",
    "turbo": "2.0.9",
    "typescript": "5.5.3"
  }
}
