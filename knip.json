{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/ai": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/web": {
      "entry": ["app/**/{page,layout,loading,error,not-found}.tsx", "next.config.mjs"],
      "project": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"]
    },
    "apps/admin": {
      "entry": ["app/**/{page,layout,loading,error,not-found}.tsx", "next.config.mjs"],
      "project": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@testing-library/dom",
        "@testing-library/react",
        "@testing-library/user-event"
      ]
    },
    "apps/api": {
      "entry": [
        "src/main.ts",
        "src/ingestion/ingest.cli.ts",
        "src/ingestion/reembed.cli.ts",
        "src/knowledge/bulk-publish.cli.ts",
        "src/consultation/backfill-tidycal.cli.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "e2e": {
      "entry": ["playwright.config.ts", "global-setup.ts", "global-teardown.ts", "specs/**/*.spec.ts"],
      "project": ["**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "ts-jest",
    "@types/jest",
    "@prisma/client"
  ],
  "ignore": ["**/*.test.ts", "**/*.test.tsx", "**/jest*.config.*", "load/**"]
}
